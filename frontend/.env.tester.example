# Tester frontend should target the isolated tester backend API.
VITE_BASE_URL=https://tester-api.aztecassess.app/api

# Enable lightweight tester onboarding checklist banner.
VITE_TESTER_ONBOARDING_ENABLED=true

# OAuth values for tester deployment
VITE_GOOGLE_CLIENT_ID=replace-google-client-id
VITE_MICROSOFT_CLIENT_ID=replace-microsoft-client-id
VITE_MICROSOFT_TENANT_ID=common
VITE_MICROSOFT_REDIRECT_URI=https://tester.aztecassess.app/auth-callback.html

