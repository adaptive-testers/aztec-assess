SECRET_KEY=replace-with-strong-secret
DEBUG=False

# Tester backend should use an isolated Neon database (or equivalent).
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require&channel_binding=require

# Tester backend host/domain settings
ALLOWED_HOSTS=tester-api.aztecassess.app
CORS_ALLOWED_ORIGINS=https://tester.aztecassess.app
CSRF_TRUSTED_ORIGINS=https://tester.aztecassess.app

# Sensitive route exposure
ENABLE_DJANGO_ADMIN=False
ENABLE_API_DOCS=False

# Controlled signup for tester cohort
SIGNUP_ALLOWLIST_ENABLED=True
STUDENT_MODE_ONLY=False

# Auth endpoint-specific throttling
AUTH_THROTTLE_LOGIN_RATE=60/hour
AUTH_THROTTLE_REGISTER_RATE=30/hour
AUTH_THROTTLE_OAUTH_RATE=60/hour
AUTH_THROTTLE_TOKEN_REFRESH_RATE=600/hour

# Cookie and transport security
COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
COOKIE_SAMESITE=None
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
USE_X_FORWARDED_HOST=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# OAuth redirect URIs must point to tester frontend domain
GOOGLE_CLIENT_ID=replace-google-client-id
GOOGLE_CLIENT_SECRET=replace-google-client-secret
GOOGLE_REDIRECT_URI=https://tester.aztecassess.app

MICROSOFT_CLIENT_ID=replace-microsoft-client-id
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://tester.aztecassess.app/auth-callback.html

