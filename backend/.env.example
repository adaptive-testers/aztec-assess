SECRET_KEY=your-secret-key-here
DEBUG=True

# Neon Database Configuration
DATABASE_URL='postgresql://username:password@host:port/database?sslmode=require&channel_binding=require'

# Django Settings
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Sensitive route exposure (recommended for staging/public deployments)
ENABLE_DJANGO_ADMIN=False
ENABLE_API_DOCS=False

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=20
JWT_REFRESH_TOKEN_LIFETIME=14

# Auth endpoint-specific throttling
AUTH_THROTTLE_LOGIN_RATE=30/hour
AUTH_THROTTLE_REGISTER_RATE=10/hour
AUTH_THROTTLE_OAUTH_RATE=30/hour
AUTH_THROTTLE_TOKEN_REFRESH_RATE=120/hour

# Cookie and transport security
COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
COOKIE_SAMESITE=Lax
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
USE_X_FORWARDED_HOST=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# Google OAuth
GOOGLE_CLIENT_ID=google-client-id
GOOGLE_CLIENT_SECRET=google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173 # or production URL

# Microsoft OAuth
MICROSOFT_CLIENT_ID=microsoft-client-id
MICROSOFT_TENANT_ID=common
# Redirect URI must match Azure app registration; frontend uses /auth-callback.html
MICROSOFT_REDIRECT_URI=http://localhost:5173/auth-callback.html
